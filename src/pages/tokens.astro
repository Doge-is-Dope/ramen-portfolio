---
import {
  colorTokens,
  radiusTokens,
  spaceTokens,
  typeTokens,
} from "@/lib/tokens";
import BaseLayout from "@/layouts/BaseLayout.astro";

type Mode = "light" | "dark";

const title = "Design tokens · Clement Liang";
const description = "Internal design-token reference for the RAMEN portfolio.";
const modes: readonly Mode[] = ["light", "dark"];
---

<BaseLayout title={title} description={description} robots="noindex,nofollow">
  <main id="main-content" tabindex="-1" class="article-shell">
    <div class="tokens-page">
      <header>
        <h1 class="tokens-page__heading">Design tokens</h1>
        <p class="tokens-page__intro">
          Single source of truth for color, typography, spacing, and radius.
          Light and dark palettes are previewed side-by-side; everything else
          renders in the light site theme.
        </p>
      </header>

      <section class="tokens-page__group" aria-labelledby="tokens-color">
        <h2 id="tokens-color" class="tokens-page__heading">Color</h2>
        {
          modes.map((mode) => (
            <div class="tokens-grid">
              {colorTokens.map((token) => {
                const value = mode === "dark" ? token.dark : token.light;
                return (
                  <div class="tokens-swatch">
                    <div
                      class="tokens-swatch__chip"
                      style={`background: ${value}`}
                      aria-hidden="true"
                    />
                    <span class="tokens-swatch__name">{token.name}</span>
                    <span class="tokens-swatch__value">{value}</span>
                    <span class="tokens-swatch__label">
                      {token.label} · {mode}
                    </span>
                  </div>
                );
              })}
            </div>
          ))
        }
      </section>

      <section class="tokens-page__group" aria-labelledby="tokens-type">
        <h2 id="tokens-type" class="tokens-page__heading">Typography</h2>
        <div class="tokens-type">
          {
            typeTokens.map((token) => (
              <div class="tokens-type__row">
                <div
                  class="tokens-type__sample"
                  style={`font-size: var(${token.name})`}
                >
                  {token.sample}
                </div>
                <div class="tokens-type__meta">
                  <span>{token.name}</span>
                  <span> · {token.label}</span>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <section class="tokens-page__group" aria-labelledby="tokens-space">
        <h2 id="tokens-space" class="tokens-page__heading">Spacing</h2>
        {
          spaceTokens.map((token) => (
            <div class="tokens-row">
              <div class="tokens-row__bar" style={`width: var(${token.name})`} />
              <div class="tokens-row__meta">
                <span>{token.name}</span>
                <span>{token.label}</span>
              </div>
            </div>
          ))
        }
      </section>

      <section class="tokens-page__group" aria-labelledby="tokens-radius">
        <h2 id="tokens-radius" class="tokens-page__heading">Radius</h2>
        {
          radiusTokens.map((token) => (
            <div class="tokens-row">
              <div
                class="tokens-row__square"
                style={`border-radius: var(${token.name})`}
              />
              <div class="tokens-row__meta">
                <span>{token.name}</span>
                <span>{token.label}</span>
              </div>
            </div>
          ))
        }
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .tokens-page {
    max-width: var(--measure-body);
    margin: 0 auto;
    padding-block: var(--space-hero-y) 6rem;
  }

  .tokens-page__group + .tokens-page__group {
    margin-top: var(--space-section);
  }

  .tokens-page__intro {
    margin: 0 0 2.5rem;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--muted);
  }

  .tokens-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .tokens-grid + .tokens-grid {
    margin-top: 1.5rem;
  }

  .tokens-swatch {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--fg);
  }

  .tokens-swatch__chip {
    width: 100%;
    height: 4rem;
    border: 1px solid var(--rule);
    border-radius: var(--radius-xs);
  }

  .tokens-swatch__name,
  .tokens-swatch__value {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
  }

  .tokens-swatch__name {
    color: var(--fg);
  }

  .tokens-swatch__value,
  .tokens-swatch__label {
    color: var(--muted);
  }

  .tokens-swatch__label {
    font-size: var(--fs-caption);
  }

  .tokens-type {
    display: flex;
    flex-direction: column;
  }

  .tokens-type__row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-block: 1rem;
    border-top: 1px solid var(--rule);
  }

  .tokens-type__row:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .tokens-type__sample {
    color: var(--fg);
    line-height: var(--lh-snug);
  }

  .tokens-type__meta {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    color: var(--muted);
  }

  .tokens-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 0.85rem;
    border-top: 1px solid var(--rule);
  }

  .tokens-row:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .tokens-row__bar {
    height: 0.75rem;
    background: var(--fg);
    border-radius: var(--radius-xs);
  }

  .tokens-row__square {
    width: 3rem;
    height: 3rem;
    background: var(--fg);
  }

  .tokens-row__meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .tokens-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
