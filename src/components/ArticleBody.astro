---
import ArticleFigure from "@/components/ArticleFigure.astro";
import InlineText from "@/components/InlineText.astro";
import BrowserRelayDiagram from "@/components/diagrams/BrowserRelayDiagram.astro";
import RuntimeDiagram from "@/components/diagrams/RuntimeDiagram.astro";
import SystemDiagram from "@/components/diagrams/SystemDiagram.astro";
import type { ArticleSection } from "@/lib/types";

type Props = {
  sections: ArticleSection[];
};

const { sections } = Astro.props;

const diagramComponents = {
  system: SystemDiagram,
  runtime: RuntimeDiagram,
  "browser-relay": BrowserRelayDiagram,
};
---

<div class="article-body">
  {
    sections.map((section) => {
      const { diagram } = section;
      const Diagram = diagram && diagramComponents[diagram.kind];
      return (
        <section id={section.id} class="article-section">
          <h2 class="article-section__title">{section.title}</h2>
          {section.paragraphs.map((paragraph) => (
            <p class="article-section__paragraph">
              <InlineText text={paragraph} />
            </p>
          ))}
          {section.items && section.items.length > 0 ? (
            <ul class="article-section__list">
              {section.items.map((item) => (
                <li>
                  <InlineText text={item} />
                </li>
              ))}
            </ul>
          ) : null}
          {section.figure ? <ArticleFigure {...section.figure} /> : null}
          {diagram && Diagram ? <Diagram caption={diagram.caption} /> : null}
        </section>
      );
    })
  }
</div>

<style>
  .article-body {
    max-width: var(--measure-body);
    margin: 0 auto;
    padding-bottom: var(--space-24);
  }

  .article-section + .article-section {
    margin-top: var(--space-section);
  }

  .article-section__paragraph {
    margin: 0 0 var(--space-4);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--fg);
  }

  .article-section__paragraph:last-child {
    margin-bottom: 0;
  }

  .article-section__list {
    margin: var(--space-4) 0 0;
    padding-left: var(--space-5);
    list-style: disc;
  }

  .article-section__list li {
    margin-bottom: var(--space-2);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }
</style>
