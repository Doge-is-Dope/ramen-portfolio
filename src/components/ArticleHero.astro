---
import type { Profile } from "@/lib/types";

type Props = {
  profile: Profile;
};

const { profile } = Astro.props;
---

<header class="article-hero">
  <p class="article-hero__meta">
    <span>{profile.reviewPeriod}</span>
    <span aria-hidden="true">&middot;</span>
    <span>{profile.kicker}</span>
  </p>
  <h1 class="article-hero__title">{profile.headline}</h1>
  <p class="article-hero__dek">{profile.dek}</p>
</header>

<style>
  .article-hero {
    max-width: var(--measure-hero);
    margin: 0 auto;
    padding-block: var(--space-hero-y) calc(var(--space-hero-y) * 0.7);
    text-align: center;
  }

  .article-hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 2rem;
    font-size: var(--fs-meta);
    font-weight: var(--fw-medium);
    color: var(--muted);
  }

  .article-hero__title {
    margin: 0 auto;
    max-width: 22ch;
    font-size: var(--fs-h1);
    font-weight: var(--fw-medium);
    letter-spacing: var(--tracking-tight);
    line-height: var(--lh-tight);
    color: var(--fg);
    text-wrap: balance;
  }

  .article-hero__dek {
    margin: 1.75rem auto 0;
    max-width: 44ch;
    font-size: var(--fs-dek);
    line-height: var(--lh-ui);
    color: var(--muted);
    text-wrap: balance;
  }
</style>
