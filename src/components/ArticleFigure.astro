---
import InlineText from "@/components/InlineText.astro";
import type { ArticleFigureProps } from "@/lib/types";
import { withBase } from "@/lib/url";

type Props = ArticleFigureProps;

const { src, alt, caption, width, height } = Astro.props;
---

<figure class="article-figure">
  <img
    src={withBase(src)}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
    class="article-figure__image"
  />
  <figcaption class="article-figure__caption">
    <InlineText text={caption} />
  </figcaption>
</figure>

<style>
  .article-figure {
    margin: var(--space-10) 0 0;
    padding: 0;
  }

  .article-figure__image {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--rule);
    border-radius: var(--radius-xs);
  }

  .article-figure__caption {
    margin-top: var(--space-3);
    font-size: var(--fs-caption);
    line-height: var(--lh-ui);
    color: var(--muted);
  }
</style>
