---
import { profile } from "@/data/profile";
---

<footer class="site-footer">
  <span class="site-footer__name">{profile.name}</span>
  <div class="site-footer__links">
    <a
      class="site-footer__link"
      href={profile.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn profile"
    >
      <svg
        class="site-footer__icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.8 0 0 .78 0 1.73v20.53C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.73C24 .78 23.2 0 22.22 0z"
        ></path>
      </svg>
    </a>
    <a
      class="site-footer__link"
      href={profile.github}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub profile"
    >
      <svg
        class="site-footer__icon"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58l-.01-2.04c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.48 5.92.43.37.81 1.1.81 2.22l-.01 3.29c0 .32.21.7.82.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"
        ></path>
      </svg>
    </a>
  </div>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    max-width: var(--measure-shell);
    margin: 0 auto;
    padding: var(--space-5) var(--space-gutter);
    border-top: 1px solid var(--rule);
    font-size: var(--fs-meta);
    font-weight: var(--fw-medium);
    color: var(--muted);
  }

  .site-footer__name {
    color: var(--fg);
  }

  .site-footer__links {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
  }

  .site-footer__link {
    display: inline-flex;
    color: var(--muted);
    transition: color 0.2s ease;
  }

  .site-footer__link:hover {
    color: var(--fg);
  }

  .site-footer__icon {
    width: var(--icon-md);
    height: var(--icon-md);
  }
</style>
