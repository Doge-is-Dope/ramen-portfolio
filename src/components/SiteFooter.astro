---
import { profile } from "@/data/profile";
---

<footer class="site-footer">
  <span class="site-footer__name">{profile.name} · {profile.role}</span>
  <span class="site-footer__updated">Last updated {profile.lastUpdated}</span>
</footer>

<style>
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: var(--measure-shell);
    margin: 0 auto;
    padding: 1.25rem var(--space-gutter);
    border-top: 1px solid var(--rule);
    font-size: var(--fs-meta);
    font-weight: var(--fw-medium);
    color: var(--muted);
  }

  .site-footer__name {
    color: var(--fg);
  }

  .site-footer__updated {
    text-align: right;
  }

  @media (max-width: 640px) {
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-footer__updated {
      text-align: left;
    }
  }
</style>
