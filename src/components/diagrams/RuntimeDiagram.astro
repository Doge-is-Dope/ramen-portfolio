---
import InlineText from "@/components/InlineText.astro";

type Props = { caption: string };

const { caption } = Astro.props;
---

<figure class="diagram-figure">
  <svg
    class="diagram diagram--compact"
    viewBox="0 0 640 524"
    role="img"
    aria-labelledby="rt-title rt-desc"
    xmlns="http://www.w3.org/2000/svg"
  >
    <title id="rt-title">RAMEN backend layering and agent runtime</title>
    <desc id="rt-desc">
      The FastAPI backend is layered presentation, application, infrastructure,
      and domain, so the agent runtime could grow without touching the API
      surface. The agent runtime turns a chat request into an SSE stream: a
      LangGraph loop with middleware and tools, an event translator, and an
      event serializer.
    </desc>

    <defs>
      <marker
        id="rt-arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="7"
        markerHeight="7"
        orient="auto-start-reverse"
      >
        <path d="M0,0 L10,5 L0,10" class="diagram__arrowhead" />
      </marker>
    </defs>

    <!-- Layer: Presentation -->
    <rect x="24" y="44" width="600" height="74" rx="6" class="diagram__group" />
    <text x="38" y="68" class="diagram__group-title diagram__anchor-start">PRESENTATION</text>
    <rect x="38" y="78" width="180" height="28" rx="4" class="diagram__node" />
    <text x="128" y="96" class="diagram__node-title">routers</text>
    <rect x="234" y="78" width="180" height="28" rx="4" class="diagram__node" />
    <text x="324" y="96" class="diagram__node-title">SSE serializer</text>
    <rect x="430" y="78" width="180" height="28" rx="4" class="diagram__node" />
    <text x="520" y="96" class="diagram__node-title">WS handler</text>

    <!-- Layer: Application -->
    <rect x="24" y="132" width="600" height="74" rx="6" class="diagram__group" />
    <text x="38" y="156" class="diagram__group-title diagram__anchor-start">APPLICATION</text>
    <rect x="38" y="166" width="180" height="28" rx="4" class="diagram__node" />
    <text x="128" y="184" class="diagram__node-title">ChatUseCase</text>
    <rect x="234" y="166" width="180" height="28" rx="4" class="diagram__node" />
    <text x="324" y="184" class="diagram__node-title">Conversation · Message</text>
    <rect x="430" y="166" width="180" height="28" rx="4" class="diagram__node" />
    <text x="520" y="184" class="diagram__node-title">events</text>

    <!-- Layer: Infrastructure -->
    <rect x="24" y="220" width="600" height="74" rx="6" class="diagram__group" />
    <text x="38" y="244" class="diagram__group-title diagram__anchor-start">INFRASTRUCTURE</text>
    <rect x="38" y="254" width="180" height="28" rx="4" class="diagram__node" />
    <text x="128" y="272" class="diagram__node-title">LangChainAgentService</text>
    <rect x="234" y="254" width="180" height="28" rx="4" class="diagram__node" />
    <text x="324" y="272" class="diagram__node-title">LLMFactory · ToolRegistry</text>
    <rect x="430" y="254" width="180" height="28" rx="4" class="diagram__node" />
    <text x="520" y="272" class="diagram__node-title">Mongo repos · ws-ticket</text>

    <!-- Layer: Domain -->
    <rect x="24" y="308" width="600" height="74" rx="6" class="diagram__group" />
    <text x="38" y="332" class="diagram__group-title diagram__anchor-start">DOMAIN</text>
    <rect x="38" y="342" width="180" height="28" rx="4" class="diagram__node" />
    <text x="128" y="360" class="diagram__node-title">entities</text>
    <rect x="234" y="342" width="180" height="28" rx="4" class="diagram__node" />
    <text x="324" y="360" class="diagram__node-title">protocols</text>
    <rect x="430" y="342" width="180" height="28" rx="4" class="diagram__node" />
    <text x="520" y="360" class="diagram__node-title">types</text>

    <!-- Agent runtime pipeline -->
    <line x1="24" y1="408" x2="624" y2="408" class="diagram__link--soft" stroke-dasharray="4 3" />
    <text x="38" y="430" class="diagram__group-title diagram__anchor-start">AGENT RUNTIME · request → stream</text>

    <rect x="38" y="444" width="118" height="40" rx="5" class="diagram__node" />
    <text x="97" y="468" class="diagram__node-title">LangGraph loop</text>
    <rect x="180" y="444" width="128" height="40" rx="5" class="diagram__node" />
    <text x="244" y="468" class="diagram__node-title">EventTranslator</text>
    <rect x="332" y="444" width="150" height="40" rx="5" class="diagram__node" />
    <text x="407" y="468" class="diagram__node-title">ChatEventSerializer</text>
    <rect x="506" y="444" width="104" height="40" rx="5" class="diagram__node" />
    <text x="558" y="468" class="diagram__node-title">SSE</text>

    <line x1="160" y1="464" x2="176" y2="464" class="diagram__link" marker-end="url(#rt-arrow)" />
    <line x1="312" y1="464" x2="328" y2="464" class="diagram__link" marker-end="url(#rt-arrow)" />
    <line x1="486" y1="464" x2="502" y2="464" class="diagram__link" marker-end="url(#rt-arrow)" />

    <text x="38" y="506" class="diagram__node-sub diagram__anchor-start">middleware: DynamicToolChoice · ToolMonitor · SubAgent &#183; tools: web_search · browser proxy</text>
  </svg>

  <figcaption class="diagram-figure__caption">
    <InlineText text={caption} />
  </figcaption>
</figure>
