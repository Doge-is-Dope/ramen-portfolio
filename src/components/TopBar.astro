---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { withBase } from "@/lib/url";

type Props = {
  activePage?: "caseStudy" | "selectedWork";
};

const { activePage } = Astro.props;
---

<header class="top-bar">
  <div class="top-bar__blur" aria-hidden="true">
    <div></div>
    <div></div>
    <div></div>
    <div></div>
  </div>
  <div class="top-bar__inner">
    <span class="top-bar__name wordmark-shimmer" data-text="RAMEN">RAMEN</span>
    <nav class="top-bar__nav" aria-label="Primary">
      <a
        href={withBase("/")}
        aria-current={activePage === "caseStudy" ? "page" : undefined}
        class="top-bar__link"
      >
        Case Study
      </a>
      <a
        href={withBase("/work/")}
        aria-current={activePage === "selectedWork" ? "page" : undefined}
        class="top-bar__link"
      >
        Selected Work
      </a>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .top-bar {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .top-bar__blur {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: calc(100% + var(--space-12));
    z-index: -1;
    pointer-events: none;
    /* Heavier dimming carries the fade so blur radii can stay low,
       which keeps text passing underneath from looking bolder. */
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, var(--bg) 94%, transparent) 0%,
      color-mix(in srgb, var(--bg) 80%, transparent) 38%,
      color-mix(in srgb, var(--bg) 44%, transparent) 66%,
      transparent 88%
    );
  }

  .top-bar__blur > div {
    position: absolute;
    inset: 0;
    --m1: 0%;
    --m2: 0%;
    --falloff: linear-gradient(
      to bottom,
      transparent var(--m1),
      #000 var(--m2),
      #000 var(--m3),
      transparent var(--m4)
    );
    -webkit-backdrop-filter: blur(var(--b));
    backdrop-filter: blur(var(--b));
    -webkit-mask-image: var(--falloff);
    mask-image: var(--falloff);
  }

  /* 4 layers, low max blur, small increments for a smooth ramp */
  .top-bar__blur > div:nth-child(1) {
    --b: 1px;
    --m3: 74%;
    --m4: 90%;
  }
  .top-bar__blur > div:nth-child(2) {
    --b: 3px;
    --m3: 52%;
    --m4: 76%;
  }
  .top-bar__blur > div:nth-child(3) {
    --b: 6px;
    --m3: 30%;
    --m4: 56%;
  }
  .top-bar__blur > div:nth-child(4) {
    --b: 10px;
    --m3: 14%;
    --m4: 36%;
  }

  .top-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--measure-shell);
    margin: 0 auto;
    padding: var(--space-5) var(--space-gutter);
    font-size: var(--fs-meta);
    font-weight: var(--fw-medium);
    color: var(--muted);
  }

  .top-bar__name {
    color: var(--fg);
    text-decoration: none;
  }

  .top-bar__nav {
    display: flex;
    gap: var(--space-5);
  }

  .top-bar__link {
    color: var(--muted);
    text-decoration: none;
    transition: color 120ms ease;
  }

  .top-bar__link:hover {
    color: var(--fg);
  }

  .top-bar__link[aria-current="page"] {
    color: var(--fg);
  }

  @media (max-width: 640px), (hover: none) and (pointer: coarse) {
    .top-bar__blur > div:nth-child(n + 2) {
      display: none;
    }

    .top-bar__blur > div:nth-child(1) {
      --b: 6px;
      --m3: 52%;
      --m4: 100%;
    }
  }

  @media (max-width: 640px) {
    .top-bar__inner {
      gap: var(--space-3);
      padding-inline: var(--space-4);
    }

    .top-bar__nav {
      min-width: 0;
      flex: 1 1 auto;
      justify-content: center;
      gap: var(--space-4);
    }

    .top-bar__name,
    .top-bar__link {
      white-space: nowrap;
    }
  }
</style>

<script>
  import { bindHoverShimmer } from "@/lib/wordmark-shimmer";

  const setupWordmarkShimmer = () => {
    bindHoverShimmer(document.querySelector<HTMLElement>(".top-bar__name"));
  };

  const setupSamePageScroll = () => {
    const bar = document.querySelector<HTMLElement>(".top-bar");
    if (!bar || bar.dataset.samePageScrollBound) return;
    bar.dataset.samePageScrollBound = "true";

    bar.addEventListener("click", (event) => {
      const link = (event.target as HTMLElement).closest<HTMLAnchorElement>(
        ".top-bar__link",
      );
      if (!link) return;

      const href = link.getAttribute("href");
      if (!href) return;
      const target = new URL(href, window.location.href);
      if (target.pathname !== window.location.pathname) return;

      event.preventDefault();
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;
      window.scrollTo({ top: 0, behavior: reduceMotion ? "auto" : "smooth" });
    });
  };

  const win = window as typeof window & { __wordmarkShimmerInit?: boolean };
  if (!win.__wordmarkShimmerInit) {
    win.__wordmarkShimmerInit = true;
    document.addEventListener("astro:page-load", setupWordmarkShimmer);
    document.addEventListener("astro:page-load", setupSamePageScroll);
  }
  setupWordmarkShimmer();
  setupSamePageScroll();
</script>
